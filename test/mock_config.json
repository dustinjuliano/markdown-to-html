{
  "source_vault": "./test/mock_vault",
  "target_site": "./test/mock_output",
  "templates": {
    "source_dir": "./test/mock_templates",
    "mapping": {
      "Articles/": "articles_layout.html",
      "default": "layout.html"
    }
  },
  "export": [
    {
      "source": "Home Page.md",
      "target": "index.html"
    },
    {
      "source": "Articles/Learning HTML.md",
      "target": "articles/learning-html/index.html"
    },
    {
